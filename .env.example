# Application Configuration
NODE_ENV=development
PORT=3001
APP_NAME=MediBook
APP_VERSION=1.0.0

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=medibook_dev
DB_USER=medibook_user
DB_PASSWORD=medibook_password
DB_ROOT_PASSWORD=root_password
DB_SSL=false
DB_POOL_SIZE=10
DB_CONNECTION_TIMEOUT=60000

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_ACCESS_SECRET=your-super-secret-access-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=medibook-system
JWT_AUDIENCE=medibook-users

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@medibook.com
EMAIL_NAME=MediBook

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# SMS Configuration (Nexmo/Vonage)
NEXMO_API_KEY=your-nexmo-api-key
NEXMO_API_SECRET=your-nexmo-api-secret
NEXMO_PHONE_NUMBER=+1234567890

# SMS Configuration (AWS SNS)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# Push Notification Configuration
VAPID_SUBJECT=mailto:admin@medibook.com
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

FCM_SERVER_KEY=your-fcm-server-key

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx

# Security Configuration
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
CORS_ORIGIN=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Session Configuration
SESSION_SECRET=your-session-secret-change-this-in-production
SESSION_TIMEOUT=3600000

# Performance Configuration
PERFORMANCE_MONITORING_ENABLED=true
SLOW_QUERY_THRESHOLD=1000
MAX_QUERY_TIME=5000
CACHE_TTL=300
MAX_CACHE_KEYS=10000

# Logging Configuration
LOG_LEVEL=info
LOG_DIR=logs
LOG_FILE=app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5
LOG_DATE_PATTERN=YYYY-MM-DD

# Monitoring Configuration
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_ENABLED=true
GRAFANA_PORT=3002
GRAFANA_ADMIN_PASSWORD=admin

# ELK Stack Configuration
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
LOGSTASH_HOST=localhost
LOGSTASH_PORT=5044
KIBANA_HOST=localhost
KIBANA_PORT=5601

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_DIR=backups
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
S3_BACKUP_BUCKET=medibook-backups
S3_REGION=us-east-1
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key

# Development Configuration
HOT_RELOAD=true
DEBUG_MODE=true
MOCK_EXTERNAL_SERVICES=false

# Testing Configuration
TEST_DB_NAME=medibook_test
TEST_REDIS_DB=1
COVERAGE_ENABLED=true
COVERAGE_THRESHOLD=80

# Production Configuration
SSL_ENABLED=true
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem
FORCE_HTTPS=true

# Health Check Configuration
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30000
HEALTH_CHECK_TIMEOUT=3000

# External Services
EXTERNAL_API_TIMEOUT=10000
EXTERNAL_API_RETRIES=3
EXTERNAL_API_BACKOFF=1000

# Feature Flags
ENABLE_REGISTRATION=true
ENABLE_EMAIL_VERIFICATION=false
ENABLE_SMS_VERIFICATION=true
ENABLE_TWO_FACTOR_AUTH=false
ENABLE_SOCIAL_LOGIN=false
ENABLE_APPOINTMENT_REMINDERS=true
ENABLE_BULK_OPERATIONS=true

# Analytics Configuration
ANALYTICS_ENABLED=true
ANALYTICS_PROVIDER=google
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX

# Social Login Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# Payment Configuration
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Notification Configuration
NOTIFICATION_QUEUE_ENABLED=true
NOTIFICATION_WORKERS=5
NOTIFICATION_RETRY_ATTEMPTS=3
NOTIFICATION_RETRY_DELAY=5000

# API Configuration
API_VERSION=v1
API_PREFIX=/api
API_DOCS_ENABLED=true
API_RATE_LIMITING=true

# WebSocket Configuration
WEBSOCKET_ENABLED=true
WEBSOCKET_PORT=3002
WEBSOCKET_PATH=/socket.io

# Maintenance Configuration
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE="System is under maintenance. Please try again later."
MAINTENANCE_START_TIME=
MAINTENANCE_END_TIME=

# GeoIP Configuration
GEOIP_ENABLED=false
GEOIP_DATABASE_PATH=./data/GeoLite2-City.mmdb

# Localization Configuration
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,es,fr,de,it,pt,ru,ja,ko,zh
LOCALE_DIR=./locales

# Search Configuration
SEARCH_ENABLED=true
SEARCH_PROVIDER=elasticsearch
SEARCH_INDEX=medibook

# Cache Configuration
MEMORY_CACHE_SIZE=100mb
REDIS_CACHE_SIZE=256mb
CACHE_STRATEGY=write-through

# Concurrency Configuration
MAX_CONCURRENT_REQUESTS=1000
MAX_CONCURRENT_UPLOADS=10
MAX_CONCURRENT_EMAILS=50

# Rate Limiting Configuration
RATE_LIMIT_STRICT=true
RATE_LIMIT_BURST=20
RATE_LIMIT_STEADY=5

# Security Headers Configuration
HELMET_ENABLED=true
CSP_ENABLED=true
HSTS_ENABLED=true

# Data Retention Configuration
DATA_RETENTION_DAYS=365
LOG_RETENTION_DAYS=90
AUDIT_RETENTION_DAYS=1095

# Compliance Configuration
GDPR_ENABLED=true
HIPAA_ENABLED=false
CCPA_ENABLED=true

# Development Tools
ENABLE_PROFILER=false
ENABLE_DEBUG_ROUTES=false
ENABLE_SWAGGER_UI=true
